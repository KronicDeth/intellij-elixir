            <separator/>
            <!--suppress PluginXmlCapitalization -->
            <action id="Elixir.InstallMixDependencies" class="org.elixir_lang.action.InstallMixDependenciesAction"
                    text="Install Mix Deps (hex, rebar, deps.get, deps.compile)"
